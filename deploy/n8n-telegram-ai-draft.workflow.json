    },
    {
      "parameters": {
        "jsCode": "const raw = String(items[0].json.output ?? '').trim();\nif (!raw) {\n  const err = items[0].json?.error?.message || items[0].json?.message || 'Пустой ответ AI Agent';\n  throw new Error(String(err).slice(0, 400));\n}\nreturn [{ json: { text: raw } }];"
      },
      "id": "aeb5d3c1-eb9a-4b4c-91d9-aaaaaaaaaa06",

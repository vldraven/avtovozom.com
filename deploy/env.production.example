# Скопируйте на сервер в /opt/avtovozom/.env и замените ВСЕ значения в угловых скобках или после «замените».
# Угловые скобки <> в финальном файле НЕ оставляйте — только реальные строки.

# ========= PostgreSQL (обязательно) =========
POSTGRES_DB=avtovozom
POSTGRES_USER=avtovozom
# Сгенерировать на сервере: openssl rand -base64 24
# Лучше без символов @ : / ? # чтобы не ломать строку подключения
POSTGRES_PASSWORD=<вставьте_длинный_пароль>

# ========= Почта SMTP (коды подтверждения на email — не SMS) =========
# Хостинг REG.RU: ЛК → Почта → настройка клиента → исходящая почта (SMTP).
# Обычно: сервер mail.hosting.reg.ru, порт 465 (SSL) или 587 (STARTTLS).
# SMTP_USER = полный email ящика; пароль = пароль ящика из панели.
# Пока SMTP_HOST пустой — письма не отправляются, коды в логах: docker compose ... logs backend

SMTP_HOST=mail.hosting.reg.ru
SMTP_PORT=465
SMTP_USER=noreply@avtovozom.com
SMTP_PASSWORD=<пароль_почтового_ящика>
SMTP_FROM=Avtovozom <noreply@avtovozom.com>

# Альтернатива: порт 587 + STARTTLS (тот же сервер):
# SMTP_PORT=587

# ========= Публичные URL сайта (прод avtovozom.com) =========
NEXT_PUBLIC_API_URL=https://api.avtovozom.com
# Канонический origin сайта для SEO (sitemap, og:url, JSON-LD). Без слэша в конце.
NEXT_PUBLIC_SITE_URL=https://avtovozom.com
CORS_ORIGINS=https://avtovozom.com,https://www.avtovozom.com
PUBLIC_WEB_ORIGIN=https://avtovozom.com

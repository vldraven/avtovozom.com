# Скопируйте на сервер в /opt/avtovozom/.env и замените ВСЕ значения в угловых скобках или после «замените».
# Угловые скобки <> в финальном файле НЕ оставляйте — только реальные строки.

# ========= PostgreSQL (обязательно) =========
POSTGRES_DB=avtovozom
POSTGRES_USER=avtovozom
# Сгенерировать на сервере: openssl rand -base64 24
# Лучше без символов @ : / ? # чтобы не ломать строку подключения
POSTGRES_PASSWORD=<вставьте_длинный_пароль>

# ========= Почта SMTP (коды регистрации и письма) =========
# Откуда взять значения:
# - Почта на домене у REG.RU / хостинга: в личном кабинете раздел «Почта» → SMTP-сервер, порт, логин, пароль ящика.
# - Яндекс (Почта для домена): SMTP smtp.yandex.ru, порт 465 (SSL) или 587 (STARTTLS), логин = полный email, пароль = пароль ящика или пароль приложения.
# - Пока не настроили почту: закомментируйте SMTP_HOST или оставьте пустым SMTP_HOST= — письма не уйдут, коды будут в логах: docker compose ... logs backend

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@avtovozom.com
SMTP_PASSWORD=<пароль_от_этого_ящика>
SMTP_FROM=Avtovozom <noreply@avtovozom.com>

# Если у провайдера только порт 587 с STARTTLS (часто у REG.RU и хостингов):
# SMTP_PORT=587
# (код бэкенда для 587 использует STARTTLS)

# ========= Публичные URL сайта (прод avtovozom.com) =========
NEXT_PUBLIC_API_URL=https://api.avtovozom.com
CORS_ORIGINS=https://avtovozom.com,https://www.avtovozom.com
PUBLIC_WEB_ORIGIN=https://avtovozom.com

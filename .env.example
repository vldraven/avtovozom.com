# Скопируйте в файл .env в корне проекта:
#   cp .env.example .env
# Файл .env в git не коммитить.

# --- PostgreSQL (обязательно для docker-compose.prod.yml) ---
POSTGRES_DB=avtovozom
POSTGRES_USER=avtovozom
# Сильный случайный пароль. В проде (docker-compose.prod.yml) пароль передаётся отдельно и кодируется в app — спецсимволы допустимы.
# Пароль в .env должен совпадать с паролем роли в PostgreSQL (при смене после первого запуска — ALTER USER, см. deploy/GITHUB_AND_DOMAIN.md).
POSTGRES_PASSWORD=замените_на_длинный_секрет

# --- Почта SMTP (коды регистрации и заявок идут на email, не SMS) ---
# Без SMTP_HOST письма не уходят — текст пишется в лог: docker compose logs backend
#
# Почта на хостинге REG.RU (раздел «Почта» → параметры для почтового клиента):
#   SMTP-сервер: mail.hosting.reg.ru
#   Порт: 465 (SSL) или 587 (STARTTLS)
#   Логин: полный адрес ящика, пароль: от этого ящика
SMTP_HOST=mail.hosting.reg.ru
SMTP_PORT=465
SMTP_USER=noreply@ваш-домен.ru
SMTP_PASSWORD=замените_на_пароль_ящика
SMTP_FROM=Avtovozom <noreply@ваш-домен.ru>
# Таймаут сокета в секундах (по умолчанию 30):
# SMTP_TIMEOUT_SEC=30

# --- Публичные URL (локально: localhost; прод: свой домен) ---
# Браузер пользователя ходит на API по этому адресу (Next вшивает в бандл при сборке web-образа — после смены пересоберите web).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Прод-пример:
# NEXT_PUBLIC_API_URL=https://api.avtovozom.com

# Публичный URL фронтенда (без слэша в конце): canonical, Open Graph, sitemap.xml, JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Прод-пример:
# NEXT_PUBLIC_SITE_URL=https://avtovozom.com

# Яндекс.Метрика — номер счётчика (только цифры), из кабинета https://metrika.yandex.ru/
# Без этой переменной счётчик не подключается. В проде задайте в .env и пересоберите образ web.
# NEXT_PUBLIC_YANDEX_METRIKA_ID=12345678

# (Опционально) URL API только для серверного кода Next (sitemap). В Docker для web задайте http://backend:8000 —
# иначе при NEXT_PUBLIC_API_URL=http://localhost:8000 запросы из контейнера не достучатся до API.
# SERVER_API_URL=http://backend:8000

# Разрешённые источники для CORS (через запятую, без пробелов):
CORS_ORIGINS=http://localhost:3000
# Прод-пример:
# CORS_ORIGINS=https://avtovozom.com,https://www.avtovozom.com

# Уведомления в Telegram о новых заявках на расчёт (опционально):
# TELEGRAM_BOT_TOKEN=
# ID чата (например @userinfobot / getUpdates) или числовой chat_id:
# TELEGRAM_ADMIN_CHAT_ID=

# Сайт для ссылок из бэкенда (чат и т.д.):
PUBLIC_WEB_ORIGIN=http://localhost:3000
# Прод-пример:
# PUBLIC_WEB_ORIGIN=https://avtovozom.com

# --- Парсер che168 (таймауты, чтобы job не зависал в RUNNING) ---
# Секунды на разбор одной карточки (HTTP + при необходимости Playwright).
# CHE168_PARSE_DETAIL_TIMEOUT_SEC=120
# Секунды на скачивание фото после создания объявления.
# CHE168_DOWNLOAD_PHOTOS_TIMEOUT_SEC=90
# Только HTTP без Playwright (если браузер недоступен):
# CHE168_SKIP_PLAYWRIGHT=1
